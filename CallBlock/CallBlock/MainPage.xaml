<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CallBlock.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label
                Text="This is a phone call screening app. It will send all incoming calls that aren't from your contacts directly to voicemail. That's all."
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
